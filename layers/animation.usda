        # 5 spheres, biggest cluster — the key release event.
        # Base path: (-5,2,0) → (-2.5,-4,0) → (0,-10,0).

        def Sphere "GTh_Core" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double radius = 0.17
            color3f[] primvars:displayColor = [(1.0, 0.95, 0.7)]
            rel material:binding = </Materials/PulseOrbGPiMaterial>
            double3 xformOp:translate.timeSamples = {
                140: (-5.0, 2.0, 0.0), 160: (-2.5, -4.0, 0.0), 180: (0.0, -10.0, 0.0)
            }
            double3 xformOp:scale.timeSamples = {
                139: (0.0, 0.0, 0.0), 140: (1.0, 1.0, 1.0), 179: (1.0, 1.0, 1.0), 180: (0.0, 0.0, 0.0)
            }
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }
