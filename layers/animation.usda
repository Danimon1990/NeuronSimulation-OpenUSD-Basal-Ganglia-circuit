# ═══════════════════════════════════════════════════════════════════════════════
# MATERIAL EMISSIVE ANIMATIONS
# ═══════════════════════════════════════════════════════════════════════════════
#
# This 'over "Materials"' block overrides the static inputs:emissiveColor values
# in shaders.usda with timeSamples, creating the pulse-triggered glow/shine.
#
# EXAM: why 'over "Materials"' at the ROOT level (not inside over "World")?
#   Materials prim is at /Materials in the stage (defined in shaders.usda as a root prim).
#   It is NOT under /World. An 'over "Materials"' inside 'over "World"' would target
#   /World/Materials — a path that does not exist. Always match the prim hierarchy.
#
# EXAM: resting values must be keyed:
#   Because this layer is STRONGEST, its timeSamples fully replace the static
#   emissiveColor from shaders.usda at ALL frames. The resting (non-active) value
#   must be explicitly keyed at frame 0 and frame 240. USD holds the nearest sample
#   outside the timeSamples range, so including both endpoints guarantees
#   the correct color at the start and end of the 240-frame timeline.

over "Materials"
{
    # ─── Cortex flash: pink-red on motor activation (frames 0-30) ────────────
    over "CortexMaterial"
    {
        over "Surface"
        {
            color3f inputs:emissiveColor.timeSamples = {
                0:   (0.0, 0.0, 0.0),
                5:   (0.5, 0.25, 0.35),
                10:  (1.5, 0.6,  0.8),
                20:  (0.8, 0.3,  0.4),
                30:  (0.0, 0.0,  0.0),
                240: (0.0, 0.0,  0.0)
            }
        }
    }

    # ─── D1 MSN flash: blue on direct pathway activation (frames 55-90) ─────
    # Resting dim blue (0.05, 0.1, 0.3) held at frames 0 and 240.
    # Peak (0.3, 0.6, 2.5) is HDR — produces visible bloom on RTX.
    over "DirectPathwayMaterial"
    {
        over "Surface"
        {
            color3f inputs:emissiveColor.timeSamples = {
                0:   (0.05, 0.1,  0.3),
                55:  (0.05, 0.1,  0.3),
                60:  (0.2,  0.4,  1.5),
                70:  (0.3,  0.6,  2.5),
                80:  (0.2,  0.4,  1.5),
                90:  (0.05, 0.1,  0.3),
                240: (0.05, 0.1,  0.3)
            }
        }
    }

    # ─── D2 MSN flash: amber on indirect pathway activation (frames 55-90) ──
    # Both D1 and D2 receive cortical input simultaneously — they compete.
    over "IndirectPathwayMaterial"
    {
        over "Surface"
        {
            color3f inputs:emissiveColor.timeSamples = {
                0:   (0.2,  0.1, 0.0),
                55:  (0.2,  0.1, 0.0),
                60:  (0.6,  0.3, 0.0),
                70:  (1.5,  0.8, 0.2),
                80:  (0.6,  0.3, 0.0),
                90:  (0.2,  0.1, 0.0),
                240: (0.2,  0.1, 0.0)
            }
        }
    }

    # ─── GPi suppression: tonic purple dims to dark (frames 110-150) ─────────
    # GPi fires tonically at 70 Hz, so it starts glowing purple.
    # KEY visual event: GPi goes dark → the gate opens → thalamus can fire.
    # Frame 120 briefly brightens (being hit by the incoming GABA wave),
    # then collapses dark. This is the most important color event in the scene.
    over "GPiMaterial"
    {
        over "Surface"
        {
            color3f inputs:emissiveColor.timeSamples = {
                0:   (0.3,  0.15, 0.5),
                110: (0.3,  0.15, 0.5),
                120: (0.6,  0.3,  1.0),
                130: (0.1,  0.05, 0.2),
                140: (0.02, 0.01, 0.04),
                150: (0.0,  0.0,  0.0),
                200: (0.0,  0.0,  0.0),
                240: (0.3,  0.15, 0.5)
            }
        }
    }

    # ─── Thalamus release: gold flash as GPi is silenced (frames 135-200) ────
    # ThalamicMaterial base emissive is zero (thalamus suppressed at rest).
    # When GPi goes dark, thalamus fires with golden glow — the victory moment.
    # Peak (1.5, 1.4, 0.8) = HDR gold. Lingers and fades over ~60 frames.
    over "ThalamicMaterial"
    {
        over "Surface"
        {
            color3f inputs:emissiveColor.timeSamples = {
                0:   (0.0,  0.0,  0.0),
                135: (0.0,  0.0,  0.0),
                142: (0.3,  0.28, 0.1),
                150: (1.5,  1.4,  0.8),
                165: (1.0,  0.95, 0.6),
                180: (0.5,  0.47, 0.25),
                200: (0.0,  0.0,  0.0),
                240: (0.0,  0.0,  0.0)
            }
        }
    }
}
