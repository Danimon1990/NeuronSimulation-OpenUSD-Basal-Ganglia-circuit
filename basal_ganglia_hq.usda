    }

    over "GPi"
    {
        over "GPi_Neuron" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </Materials/GPiMaterial> (
                bindMaterialAs = "weakerThanDescendants"
            )
            float3 xformOp:rotateXYZ = (-87.718, 2.1650624, 4.795331)
            float3 xformOp:scale = (0.71582896, 1, 1.2141265)
            double3 xformOp:translate = (0.21715739399252065, 0.7565165272217635, -0.5363055626650921)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]

            over "Sphere"
            {
                over "Sphere"
                {
                    quatf xformOp:orient = (1, 0, 0, 0)
                    float3 xformOp:scale = (1, 1, 1)
                    double3 xformOp:translate = (0, 0, 0)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
                }
            }
        }
    }

    over "Striatum"
    {
