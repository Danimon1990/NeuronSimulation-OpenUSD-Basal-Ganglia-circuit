    def Camera "Cam_DopamineSide" (
        prepend apiSchemas = ["OmniRtxCameraAutoExposureAPI_1", "OmniRtxCameraExposureAPI_1"]
        doc = "Side view of SNc. Use full 240 frames. Yellow-green dopamine particles rise continuously."
    )
    {
