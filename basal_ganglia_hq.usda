            }

            over "env_light"
            {
                color3f inputs:color = (0.1871755, 0.06576298, 1.9599999)
                float inputs:colorTemperature = 6500
                float inputs:exposure = -0.5
                float inputs:intensity = 0.2
                token visibility = "inherited"
