        float verticalAperture = 20.25
        token visibility = "invisible"
        double3 xformOp:rotateYXZ = (90, -0, 6.300000190734863)
        double3 xformOp:rotateYXZ.timeSamples = {
            0: (90, 0, 0),
            120: (90, 4, 0),
            240: (90, 7, 0),
